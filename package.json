{
  "name": "agent-data-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Agent benchmark dataset discovery, schema harvesting, and data package generation.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
